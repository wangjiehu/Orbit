{
  "name": "@orbit-build/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "orbit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@orbit-build/shared": "workspace:*",
    "@orbit-build/config": "workspace:*",
    "@orbit-build/core": "workspace:*",
    "@orbit-build/tui": "workspace:*",
    "@orbit-build/model-providers": "workspace:*",
    "@orbit-build/context-engine": "workspace:*",
    "@orbit-build/permissions": "workspace:*",
    "picocolors": "^1.0.1",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  }
}

